# Root .env template for docker-compose.
# Copy to .env and adjust if you want non-default values.
# .env is gitignored. Only this .env.example is committed.
# All values below are DEMO-ONLY placeholders for local development.
# In any real deployment, override POSTGRES_PASSWORD and SECRET_KEY via env vars.

# --- Postgres ---
POSTGRES_USER=shoplite
POSTGRES_PASSWORD=shoplite
POSTGRES_DB=shoplite

# --- Backend ---
SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
