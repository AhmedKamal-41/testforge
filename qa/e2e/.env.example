# Copy to .env and adjust. Loaded by playwright.config.ts via dotenv if present.
# Used by Playwright tests.
# Only this .env.example is committed; .env is gitignored.

# Where ShopLite is reachable. The frontend nginx proxies /api → backend.
PLAYWRIGHT_BASE_URL=http://localhost:5173

# DEMO-ONLY seed credentials — these are fake local/demo accounts used only for
# development and automated tests. They must match apps/backend/app/seeds/seed.py.
# Not real secrets; the seed file commits them on purpose so reviewers can run
# the suite immediately.
SHOPLITE_ADMIN_EMAIL=admin@shoplite.io
SHOPLITE_ADMIN_PASSWORD=admin123
SHOPLITE_USER_EMAIL=user@shoplite.io
SHOPLITE_USER_PASSWORD=user1234
