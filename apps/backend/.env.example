# Copy to .env and adjust for your environment.
# .env is gitignored. Only this .env.example is committed.
# All values below are DEMO-ONLY placeholders for local development.
# In any real deployment, override SECRET_KEY and DATABASE_URL via env vars.

# --- App ---
APP_ENV=local
SECRET_KEY=dev-secret-change-me-in-real-deployments
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database ---
# Production / local-dev DB (PostgreSQL via psycopg3).
DATABASE_URL=postgresql+psycopg://shoplite:shoplite@localhost:5432/shoplite

# Test DB. Default is SQLite so `pytest` runs without external services.
# In Phase 3+ (Docker) we switch this to a real Postgres test DB.
TEST_DATABASE_URL=sqlite:///./shoplite_test.db

# --- CORS ---
# Frontend origin(s), comma-separated. Defaults to Vite dev server.
CORS_ORIGINS=http://localhost:5173
